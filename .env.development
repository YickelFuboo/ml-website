# 用户管理服务：留空则走 Vite 代理 /api，代理目标为 http://127.0.0.1:8001
VITE_API_USER_SERVICE_URL=http://127.0.0.1:8001

# 产品管理服务（产品与版本），默认 http://localhost:8002
VITE_API_PRODUCT_SERVICE_URL=http://localhost:8002

# 知识库原子服务（知识库与文档），默认 http://localhost:8003
VITE_API_KNOWLEDGEBASE_SERVICE_URL=http://localhost:8003

# AIAgent Worker 服务（智能助手 WebSocket + REST），默认 http://localhost:8008
VITE_API_AGENT_WORKER_SERVICE_URL=http://localhost:9001
